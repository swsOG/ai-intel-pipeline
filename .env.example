# Login credentials
ADMIN_USERNAME=your_username
ADMIN_PASSWORD=CHANGE_THIS_TO_YOUR_PASSWORD

# Flask
FLASK_SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_STRING

# Gemini API (get from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# Gmail (for email delivery)
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Pipeline security
PIPELINE_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING
